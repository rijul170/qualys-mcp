# =============================================================================
# Qualys MCP — per-console environment (one file per console instance)
# Copy to .env.consulting / .env.cloud, or feed via the PowerShell launcher
# which decrypts DPAPI secrets and sets these at runtime.
# =============================================================================

# --- Credentials (API user; a dedicated service account is recommended) ------
QUALYS_USERNAME=your-api-username
QUALYS_PASSWORD=your-api-password

# --- Platform / POD ----------------------------------------------------------
# Set QUALYS_PLATFORM to auto-fill both API and Gateway base URLs.
# Known codes: US1 US2 US3 US4 EU1 EU2 EU3 IN1 CA1 AE1 UK1 AU1 KSA1
# Find yours under the console URL or Help > About.
QUALYS_PLATFORM=US2
# Or override explicitly (takes precedence / needed for unlisted PODs):
#QUALYS_API_URL=https://qualysapi.qg2.apps.qualys.com
#QUALYS_GATEWAY_URL=https://gateway.qg2.apps.qualys.com

# --- Namespacing -------------------------------------------------------------
# Label distinguishes the two consoles in logs and the MCP server name.
QUALYS_CONSOLE_LABEL=consulting

# --- Safety ------------------------------------------------------------------
# Destructive tools (delete/purge/deactivate) are HIDDEN unless this is true.
# Even when true, each destructive tool still requires an explicit confirm arg.
QUALYS_ENABLE_DESTRUCTIVE=false

# --- Module selection --------------------------------------------------------
# Comma-separated module names to enable (default: all discovered modules).
# Scope each console to only its licensed modules to keep the tool list tight.
#QUALYS_MCP_MODULES=vmscans,knowledgebase,hostassets,reports,...

# --- Transport / server ------------------------------------------------------
QUALYS_MCP_TRANSPORT=streamable-http
QUALYS_MCP_HOST=127.0.0.1
QUALYS_MCP_PORT=8781
#QUALYS_MCP_API_KEY=optional-shared-secret-for-http-transport
#QUALYS_MCP_STATELESS_HTTP=false

# --- Misc --------------------------------------------------------------------
QUALYS_REQUESTED_WITH=qualys-mcp
QUALYS_VERIFY_TLS=true
QUALYS_TIMEOUT=300
QUALYS_MAX_RETRIES=4
QUALYS_DEBUG=false
